   1:Core/Src/audio_test.c **** #include "audio_test.h"
   2:Core/Src/audio_test.c **** 
   3:Core/Src/audio_test.c **** #include "i2s.h"
   4:Core/Src/audio_test.c **** #include <math.h>
   5:Core/Src/audio_test.c **** #include <stdint.h>
   6:Core/Src/audio_test.c **** 
   7:Core/Src/audio_test.c **** #define AUDIO_SAMPLE_RATE_HZ     48000u
   8:Core/Src/audio_test.c **** #define SINE_FREQ_HZ             1000u
   9:Core/Src/audio_test.c **** #define SINE_TABLE_SIZE          (AUDIO_SAMPLE_RATE_HZ / SINE_FREQ_HZ)
  10:Core/Src/audio_test.c **** 
  11:Core/Src/audio_test.c **** /*
  12:Core/Src/audio_test.c ****  * 480 frames = 10 complete periods of a 1 kHz sine at 48 kHz.
  13:Core/Src/audio_test.c ****  * This avoids a discontinuity when circular DMA wraps.
  14:Core/Src/audio_test.c ****  */
  15:Core/Src/audio_test.c **** #define AUDIO_BUFFER_FRAMES      480u
  16:Core/Src/audio_test.c **** #define AUDIO_CHANNELS           2u
  17:Core/Src/audio_test.c **** #define HALFWORDS_PER_SAMPLE     2u
  18:Core/Src/audio_test.c **** 
  19:Core/Src/audio_test.c **** /*
  20:Core/Src/audio_test.c ****  * For 32-bit stereo I2S, each audio frame is:
  21:Core/Src/audio_test.c ****  *
  22:Core/Src/audio_test.c ****  * Left  channel: 32 bits = 2 x uint16_t DMA writes
  23:Core/Src/audio_test.c ****  * Right channel: 32 bits = 2 x uint16_t DMA writes
  24:Core/Src/audio_test.c ****  *
  25:Core/Src/audio_test.c ****  * Buffer layout:
  26:Core/Src/audio_test.c ****  *
  27:Core/Src/audio_test.c ****  * audio_buffer[0] = left high halfword
  28:Core/Src/audio_test.c ****  * audio_buffer[1] = left low  halfword
  29:Core/Src/audio_test.c ****  * audio_buffer[2] = right high halfword
  30:Core/Src/audio_test.c ****  * audio_buffer[3] = right low  halfword
ARM GAS  /tmp/cckxqfOY.s 			page 2


  31:Core/Src/audio_test.c ****  * audio_buffer[4] = next left high halfword
  32:Core/Src/audio_test.c ****  * ...
  33:Core/Src/audio_test.c ****  */
  34:Core/Src/audio_test.c **** static uint16_t audio_buffer[AUDIO_BUFFER_FRAMES * AUDIO_CHANNELS * HALFWORDS_PER_SAMPLE];
  35:Core/Src/audio_test.c **** 
  36:Core/Src/audio_test.c **** static int32_t sine_table[SINE_TABLE_SIZE];
  37:Core/Src/audio_test.c **** 
  38:Core/Src/audio_test.c **** static void sine_table_init(void)
  39:Core/Src/audio_test.c **** {
  40:Core/Src/audio_test.c ****     /*
  41:Core/Src/audio_test.c ****      * Start quiet. Increase later once the waveform looks correct.
  42:Core/Src/audio_test.c ****      */
  43:Core/Src/audio_test.c ****     const float amplitude = 0.1f * 2147483647.0f;
  44:Core/Src/audio_test.c **** 
  45:Core/Src/audio_test.c ****     for (uint32_t i = 0; i < SINE_TABLE_SIZE; i++)
  46:Core/Src/audio_test.c ****     {
  47:Core/Src/audio_test.c ****         float phase = 2.0f * 3.14159265359f * (float)i / (float)SINE_TABLE_SIZE;
  48:Core/Src/audio_test.c ****         sine_table[i] = (int32_t)(amplitude * sinf(phase));
  49:Core/Src/audio_test.c ****     }
  50:Core/Src/audio_test.c **** }
  51:Core/Src/audio_test.c **** 
